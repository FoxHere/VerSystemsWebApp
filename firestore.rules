rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Match para /tasks/** (restrito ao usuário logado)
    match /tasks/{allPaths=**} {
      allow read, write: if true;
    }

    // 2. Bloqueia todas as outras pastas (por segurança)
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}